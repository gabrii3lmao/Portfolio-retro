---
import { Icon } from "astro-icon/components";
import { tagIcons } from "../lib/tagIcons";
import Anchor from "./common/Anchor.astro";

export type Props = {
	title: string;
	description: string;
	url: string;
	githubUrl?: string;
	liveUrl?: string;
	tags: string[];
};

const { title, description, url, githubUrl, liveUrl, tags } = Astro.props;
---

<div class="relative flex flex-col gap-3 mb-8 hover-zag-dotted-grid">
  <div class="flex flex-col gap-3 sm:flex-row sm:justify-between">
    <Anchor url={url} class="text-xl">
      {title}
    </Anchor>
    <div class="flex gap-2">
      {
        githubUrl ? (
          <Anchor url={githubUrl} class="text-base" external>
            GitHub
          </Anchor>
        ) : null
      }
      {
        liveUrl ? (
          <Anchor url={liveUrl} class="text-base" external>
            Live
          </Anchor>
        ) : null
      }
    </div>
  </div>
  <p class="zag-text zag-transition">
    {description}
  </p>
  <div class="flex flex-row flex-wrap gap-2">
    {
      tags.map((tag) => (
        <span class="-zag-text -zag-bg zag-transition px-2 py-1 text-sm font-semibold flex items-center gap-1">
          {tagIcons[tag.toLowerCase()] && (
            <Icon name={tagIcons[tag.toLowerCase()]} class="w-3.5 h-3.5" />
          )}
          {tag}
        </span>
      ))
    }
  </div>
</div>
