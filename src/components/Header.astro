---
import { Icon } from "astro-icon/components";
import { getConfigurationCollection } from "../lib/utils";
import Anchor from "./common/Anchor.astro";
import ThemeToggle from "./ThemeToggle.astro";

const { data: config } = await getConfigurationCollection();
---
<header class="zag-bg zag-border-b zag-transition sticky top-0 w-full z-10">
  <div
    class="zag-bg zag-transition sm:hidden relative z-50 py-4 flex items-center"
  >
    <button class="px-4 min-h-11 min-w-11 flex items-center justify-center" type="button" aria-label="Toggle navigation menu">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="32"
        height="32"
        viewBox="0 0 512 512"
        class="zag-fill zag-transition"
      >
        <title>Menu de navegação</title>
        <path d="M80 96h352v32H80zm0 144h352v32H80zm0 144h352v32H80z"></path>
      </svg>
    </button>
  </div>
  <div id="navOverlay" class="hidden sm:hidden fixed inset-0 bg-neutral-900/50 z-40"></div>
  <nav
    id="navMenu"
    class="zag-bg zag-border-b zag-transition fixed sm:relative inset-x-0 top-0 h-auto sm:px-4 flex justify-between flex-col gap-8 py-6 sm:py-4 text-xl sm:flex-row max-w-2xl mx-auto sm:pt-4 sm:border-none z-50"
  >
    <div
      class="flex flex-col font-mono font-medium gap-4 sm:flex-row px-4 sm:px-0 mt-16 sm:mt-0"
    >
      {
        Object.entries(config.menu).map((i) => (
          <Anchor url={i[1]} class="py-2 sm:py-0 min-h-11 sm:min-h-0 flex items-center">{i[0]}</Anchor>
        ))
      }
    </div>
    <div class="flex gap-4 justify-between px-4 sm:px-0">
      <a
        href="/Gabriel_Moura_Luz_Curriculo.pdf"
        download
        aria-label="Baixar currículo"
        class="zag-fill zag-transition min-h-11 min-w-11 flex items-center justify-center"
      >
        <Icon name="simple-icons:readdotcv" class="w-8 h-8" />
      </a>
      {
        config.personal.githubProfile && (
          <Anchor
            url={config.personal.githubProfile}
            aria-label={`Perfil do GitHub de ${config.personal.name}`}
          >
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="32"
              height="32"
              viewBox="0 0 24 24"
              class="zag-fill zag-transition"
            >
              <title>GitHub</title>
              <path d="M12 2A10 10 0 0 0 2 12c0 4.42 2.87 8.17 6.84 9.5c.5.08.66-.23.66-.5v-1.69c-2.77.6-3.36-1.34-3.36-1.34c-.46-1.16-1.11-1.47-1.11-1.47c-.91-.62.07-.6.07-.6c1 .07 1.53 1.03 1.53 1.03c.87 1.52 2.34 1.07 2.91.83c.09-.65.35-1.09.63-1.34c-2.22-.25-4.55-1.11-4.55-4.92c0-1.11.38-2 1.03-2.71c-.1-.25-.45-1.29.1-2.64c0 0 .84-.27 2.75 1.02c.79-.22 1.65-.33 2.5-.33s1.71.11 2.5.33c1.91-1.29 2.75-1.02 2.75-1.02c.55 1.35.2 2.39.1 2.64c.65.71 1.03 1.6 1.03 2.71c0 3.82-2.34 4.66-4.57 4.91c.36.31.69.92.69 1.85V21c0 .27.16.59.67.5C19.14 20.16 22 16.42 22 12A10 10 0 0 0 12 2" />
            </svg>
          </Anchor>
        )
      }
      <ThemeToggle />
    </div>
  </nav>
</header>

<script>
  const button = document.querySelector("button") as HTMLButtonElement;
  const nav = document.getElementById("navMenu") as HTMLElement;
  const overlay = document.getElementById("navOverlay") as HTMLElement;
  let isOpen = false;

  function updateNavState() {
    const isMobile = window.matchMedia("(max-width: 640px)").matches;
    if (isMobile) {
      nav.style.transform = isOpen ? "translateY(0)" : "translateY(-100%)";
      overlay.classList.toggle("hidden", !isOpen);
    } else {
      nav.style.transform = "translateY(0)";
      overlay.classList.add("hidden");
      isOpen = false;
    }
  }

  function toggleNav() {
    isOpen = !isOpen;
    updateNavState();
  }

  function closeNav() {
    if (isOpen) {
      isOpen = false;
      updateNavState();
    }
  }

  button?.addEventListener("click", toggleNav);
  overlay?.addEventListener("click", closeNav);
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape") closeNav();
  });
  window.addEventListener("resize", updateNavState);

  updateNavState();
</script>
